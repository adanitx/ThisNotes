{
  "manifest_version": 3,
  "name": "ThisNotes",
  "description": "Notas persistentes por sitio web con estilos configurables.",
  "version": "1.1.0",
  "icons": {
    "16": "Icono ThisNotes.png",
    "32": "Icono ThisNotes.png",
    "48": "Icono ThisNotes.png",
    "128": "Icono ThisNotes.png"
  },
  "permissions": ["storage", "tabs", "scripting"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_title": "ThisNotes",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "Icono ThisNotes.png",
      "32": "Icono ThisNotes.png",
      "48": "Icono ThisNotes.png",
      "128": "Icono ThisNotes.png"
    }
  },
  "options_page": "options.html",
  "browser_specific_settings": {
    "gecko": {
      "id": "thisnotes@local",
      "strict_min_version": "121.0"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
